{
  "name": "milos-rankovic-portfolio",
  "version": "1.0.0",
  "description": "Milos Rankovic Protfolio Website",
  "repository": {
    "type": "git",
    "url": "https://github.com/milosRank/milos-rankovic-portfolio.git"
  },
  "main": "index.js",
  "scripts": {
    "build-global": "sass assets/scss/_global.scss --style=expanded --quiet | postcss --use autoprefixer --no-map > assets/css/build/global.css",
    "build-partials": "sass assets/scss/partials/_partials.scss --style=expanded --quiet | postcss --use autoprefixer --no-map > assets/css/build/partials.css",
    "build-bootstrap": "sass assets/scss/bootstrap.scss --style=expanded --quiet | postcss --use autoprefixer --no-map > assets/css/bootstrap.css",
    "build-sections": "sass assets/scss/sections/_all-sections.scss --style=expanded --quiet | postcss --use autoprefixer --no-map > assets/css/build/all-sections.css",
    "build-main": "sass assets/scss/main.scss --style=expanded --quiet | postcss --use autoprefixer --no-map > assets/css/build/main.css",
    "build-all": "npm-run-all build-global build-partials build-bootstrap build-sections build-main"
},
  "author": "Milos Rankovic",
  "license": "ISC",
  "dependencies": {
    "autoprefixer": "^10.4.16",
    "bootstrap": "^5.3.2",
    "bootstrap-grid": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.31",
    "postcss-cli": "^10.1.0",
    "sass": "^1.69.4"
  }
}
